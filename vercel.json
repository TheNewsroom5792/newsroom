{
  "version": 2,
  "routes": [
    {
      "src": "/app",
      "dest": "/public/app.html"
    },
    {
      "src": "/admin",
      "dest": "/public/public/admin.html"
    },
    {
      "src": "/fresh-start",
      "dest": "/public/fresh-start.html"
    },
    {
      "src": "/manifest.json",
      "dest": "/public/manifest.json"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/app.html",
      "dest": "/public/app.html"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 12 * * *"
    }
  ]
}