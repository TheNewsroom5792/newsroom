{
  "version": 2,
  "routes": [
    {
      "src": "/beta",
      "dest": "/public/beta.html"
    },
    {
      "src": "/beta.html",
      "dest": "/public/beta.html"
    },
    {
      "src": "/app",
      "dest": "/public/app.html"
    },
    {
      "src": "/admin",
      "dest": "/public/public/admin.html"
    },
    {
      "src": "/fresh-start",
      "dest": "/public/fresh-start.html"
    },
    {
      "src": "/privacy",
      "dest": "/public/privacy.html"
    },
    {
      "src": "/terms",
      "dest": "/public/terms.html"
    },
    {
      "src": "/manifest.json",
      "dest": "/public/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "/public/sw.js"
    },
    {
      "src": "/icon-192.svg",
      "dest": "/public/icon-192.svg"
    },
    {
      "src": "/icon-512.svg",
      "dest": "/public/icon-512.svg"
    },
    {
      "src": "/og-image.svg",
      "dest": "/public/og-image.svg"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/app.html",
      "dest": "/public/app.html"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "/unsubscribe",
      "dest": "/api/unsubscribe"
    },
    {
      "src": "/contact",
      "dest": "/public/contact.html"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/public/sitemap.xml"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1",
      "status": 200
    },
    {
      "src": "/404",
      "dest": "/public/404.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 7 * * *"
    }
  ]
}